@page "/users"
@using CopelinSystem.Models
@using CopelinSystem.Services
@inject UserService UserService
@inject EmployeeService EmployeeService
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthenticationService AuthService
@inject PermissionService PermissionService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>AD Management - Copelin Work Flow Management</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (canManageUsers)
        {
            <div class="container-fluid mt-3">
                <!-- Header -->
                <div class="row mb-3 align-items-center">
                    <div class="col-md-8">
                        <h3><i class="fas fa-users-cog"></i> Active Directory Management</h3>
                        <p class="text-muted mb-0">Manage user accounts and Active Directory credentials</p>
                    </div>
                    <div class="col-md-4 text-right">
                        <button class="btn btn-success" @onclick="OpenCreateModal">
                            <i class="fas fa-plus"></i> Add New User
                        </button>
                    </div>
                </div>

                <!-- Users Table -->
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        @if (users == null)
                        {
                            <div class="text-center p-4">
                                <i class="fas fa-spinner fa-spin text-primary mr-2"></i> Loading users...
                            </div>
                        }
                        else if (!users.Any())
                        {
                            <div class="text-center p-4 text-muted">
                                No users found.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-striped mb-0">
                                    <thead class="thead-light">
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Region</th>
                                            <th>Role</th>
                                            <th>AD Identity</th>
                                            <th>Last Active</th>
                                            <th class="text-right">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in users)
                                        {
                                            <tr>
                                                <td class="align-middle font-weight-bold">@user.DisplayName</td>
                                                <td class="align-middle">@user.Email</td>
                                                <td class="align-middle">@(user.Region ?? "-")</td>
                                                <td class="align-middle">
                                                    <span class="badge @GetRoleBadgeClass((UserRole)user.UserType)">@(((UserRole)user.UserType).ToString())</span>
                                                </td>
                                                <td class="align-middle">
                                                    @if (!string.IsNullOrEmpty(user.AdDomain) && !string.IsNullOrEmpty(user.AdUsername))
                                                    {
                                                        <code class="text-dark bg-light px-2 py-1 rounded border">@user.AdDomain\@user.AdUsername</code>
                                                    }
                                                    else
                                                    {
                                                        <code class="text-muted bg-light px-2 py-1 rounded border">@(user.AdUsername ?? "-")</code>
                                                    }
                                                </td>
                                                <td class="align-middle">@(user.LastActive?.ToString("MMM dd, yyyy HH:mm") ?? "Never")</td>
                                                <td class="align-middle text-right text-nowrap">
                                                    <button class="btn btn-sm btn-outline-primary mr-1" @onclick="() => OpenEditModal(user)" title="Edit User">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(user)" title="Delete User">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <!-- Create/Edit Modal -->
                @if (showModal)
                {
                    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6);" @onclick:stopPropagation="true">
                        <div class="modal-dialog modal-lg modal-dialog-centered">
                            <div class="modal-content shadow">
                                <div class="modal-header bg-light">
                                    <h5 class="modal-title font-weight-bold">
                                        <i class="fas @(isEditing ? "fa-user-edit" : "fa-user-plus") text-primary mr-2"></i>
                                        @(isEditing ? $"Edit User: {currentUserEdit.DisplayName}" : "Create New User")
                                    </h5>
                                    <button type="button" class="close" @onclick="CloseModal">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <div class="modal-body p-4">
                                    <!-- Personal Info -->
                                    <h6 class="text-primary border-bottom pb-2 mb-3"><i class="fas fa-id-card mr-2"></i> Personal Information</h6>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="font-weight-bold">First Name <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" @bind="currentUserEdit.Firstname" placeholder="Enter first name" required />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="font-weight-bold">Last Name</label>
                                                <input type="text" class="form-control" @bind="currentUserEdit.Lastname" placeholder="Enter last name" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="font-weight-bold">Email</label>
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                            </div>
                                            <input type="email" class="form-control" @bind="currentUserEdit.Email" placeholder="user@example.com" />
                                        </div>
                                    </div>

                                    <!-- System Access -->
                                    <h6 class="text-primary border-bottom pb-2 mb-3 mt-4"><i class="fas fa-key mr-2"></i> System Access</h6>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="font-weight-bold">Role</label>
                                                <select class="form-control custom-select" @bind="userTypeInt">
                                                    @foreach (UserRole role in Enum.GetValues(typeof(UserRole)))
                                                    {
                                                        <option value="@((int)(byte)role)">@role</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="font-weight-bold">Region</label>
                                                <input type="text" class="form-control" @bind="currentUserEdit.Region" placeholder="e.g., SWQ- South West Qld" />
                                                <small class="form-text text-muted">Used for regional filtering</small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Authentication Methods -->
                                    <h6 class="text-primary border-bottom pb-2 mb-3 mt-4"><i class="fas fa-lock mr-2"></i> Authentication Methods</h6>
                                    
                                    <div class="row">
                                        <!-- Local Credentials -->
                                        <div class="col-md-6 border-right pr-4">
                                            <h6 class="font-weight-bold mb-3"><i class="fas fa-user-shield text-muted mr-1"></i> Local Credentials</h6>
                                            <p class="small text-muted mb-3">Users can log in using their email address and a local password.</p>
                                            
                                            <div class="form-group mb-0">
                                                <label class="font-weight-bold">Password</label>
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text"><i class="fas fa-key"></i></span>
                                                    </div>
                                                    <input type="password" class="form-control" @bind="newPassword" placeholder="@(isEditing ? "Leave blank to keep current" : "Enter a secure password")" />
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Active Directory (SSO) -->
                                        <div class="col-md-6 pl-4">
                                            <h6 class="font-weight-bold mb-3"><i class="fab fa-windows text-muted mr-1"></i> Active Directory (SSO)</h6>
                                            <p class="small text-muted mb-3">Allow users to log in securely using their Windows domain credentials.</p>
                                            
                                            @if(isEditing)
                                            {
                                                <div class="alert alert-warning py-1 px-2 mb-3 small">
                                                    <i class="fas fa-exclamation-triangle mr-1"></i> Changing these values may prevent the user from logging in via AD.
                                                </div>
                                            }
                                            
                                            <div class="form-group mb-2">
                                                <label class="font-weight-bold small mb-1">Directory Domain</label>
                                                <input type="text" class="form-control form-control-sm" @bind="currentUserEdit.AdDomain" placeholder="e.g., COPELIN" />
                                            </div>
                                            
                                            <div class="form-group mb-2">
                                                <label class="font-weight-bold small mb-1">Directory Username</label>
                                                <input type="text" class="form-control form-control-sm" @bind="currentUserEdit.AdUsername" placeholder="e.g., jsmith" />
                                            </div>
                                            
                                            <div class="form-group mb-0">
                                                <label class="font-weight-bold small mb-1">Security Identifier (SID)</label>
                                                <input type="text" class="form-control form-control-sm" @bind="currentUserEdit.AdSid" placeholder="Auto-populated upon first Windows login" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer bg-light">
                                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">
                                        <i class="fas fa-times"></i> Cancel
                                    </button>
                                    <button type="button" class="btn btn-primary" @onclick="SaveUser">
                                        <i class="fas fa-save"></i> @(isEditing ? "Save Changes" : "Create User")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Modal Backdrop -->
                    <div class="modal-backdrop fade show"></div>
                }
            </div>
        }
        else
        {
            <div class="container mt-5">
                <div class="alert alert-danger text-center shadow-sm">
                    <h4 class="alert-heading"><i class="fas fa-ban fa-2x mb-3 d-block text-danger"></i>Access Denied</h4>
                    <p>You do not have permission to access the Active Directory Management page.</p>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="container mt-5">
            <div class="card shadow-sm mx-auto" style="max-width: 500px;">
                <div class="card-body text-center p-5">
                    <i class="fas fa-lock fa-3x text-muted mb-4 d-block"></i>
                    <h4 class="card-title mb-4">Authentication Required</h4>
                    <a href="/login" class="btn btn-primary btn-lg px-5">Go to Login</a>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private User? currentUser;
    private bool canManageUsers = false;
    private List<User>? users;
    private List<Region>? regions;
    private bool showModal = false;
    private bool isEditing = false;
    private User currentUserEdit = new();
    private int userTypeInt;
    private string newPassword = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst("UserId");
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
            {
                currentUser = await AuthService.GetUserById(userId);
                if (currentUser != null)
                {
                    canManageUsers = await PermissionService.UserHasPermission(currentUser, "ManageUsers");
                }
            }
        }

        if (canManageUsers)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        users = await UserService.GetAllUsers();
        regions = await EmployeeService.GetAllRegions();
    }

    private void OpenCreateModal()
    {
        isEditing = false;
        currentUserEdit = new User
        {
            UserType = (byte)UserRole.ReadOnly // Default
        };
        userTypeInt = (int)UserRole.ReadOnly;
        newPassword = "";
        showModal = true;
    }

    private void OpenEditModal(User user)
    {
        isEditing = true;
        // Clone the user to avoid editing the list directly
        currentUserEdit = new User
        {
            UserId = user.UserId,
            Firstname = user.Firstname,
            Lastname = user.Lastname,
            Email = user.Email,
            Region = user.Region,
            UserType = user.UserType,
            AdUsername = user.AdUsername,
            AdDomain = user.AdDomain,
            AdSid = user.AdSid,
            Avatar = user.Avatar,
            DateCreated = user.DateCreated,
            LastActive = user.LastActive
        };
        
        // Convert byte UserType to int for dropdown binding
        userTypeInt = currentUserEdit.UserType;
        newPassword = "";
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        currentUserEdit = new();
        isEditing = false;
    }

    private async Task SaveUser()
    {
        // Basic validation
        if (string.IsNullOrWhiteSpace(currentUserEdit.Firstname))
        {
            await JSRuntime.InvokeVoidAsync("Notifications.showError", "First name is required.");
            return;
        }

        // Update role from int
        currentUserEdit.UserType = (byte)userTypeInt;

        if (isEditing)
        {
            bool confirmed = await JSRuntime.InvokeAsync<bool>("Notifications.showConfirm", "Are you sure you want to save these changes?");
            if (confirmed)
            {
                await UserService.UpdateUser(currentUserEdit, newPassword);
                await LoadData();
                CloseModal();
                await JSRuntime.InvokeVoidAsync("Notifications.showSuccess", "User updated successfully!");
            }
        }
        else
        {
            // Creation logic
            await UserService.CreateUser(currentUserEdit, newPassword);
            await LoadData();
            CloseModal();
            await JSRuntime.InvokeVoidAsync("Notifications.showSuccess", "User created successfully!");
        }
    }

    private async Task DeleteUser(User user)
    {
        // Don't let users delete themselves to prevent getting locked out
        if (currentUser != null && user.UserId == currentUser.UserId)
        {
            await JSRuntime.InvokeVoidAsync("Notifications.showError", "You cannot delete your own account while logged in.");
            return;
        }
    
        bool confirmed = await JSRuntime.InvokeAsync<bool>("Notifications.showConfirm", $"Are you sure you want to permanently delete {user.DisplayName}? This action cannot be undone.");
        
        if (confirmed)
        {
            bool success = await UserService.DeleteUser(user.UserId);
            if (success)
            {
                await LoadData();
                await JSRuntime.InvokeVoidAsync("Notifications.showSuccess", "User deleted successfully.");
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("Notifications.showError", "Error deleting user. They may have related records preventing deletion.");
            }
        }
    }

    private string GetRoleBadgeClass(UserRole role)
    {
        return role switch
        {
            UserRole.Admin => "badge-danger",
            UserRole.PrincipalEstimator => "badge-warning text-dark",
            UserRole.Manager => "badge-info",
            UserRole.Estimator => "badge-primary",
            _ => "badge-secondary"
        };
    }
}
